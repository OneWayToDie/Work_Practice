<Window x:Class="Work_Practice.Views.Task1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Work_Practice.UserControls"
        xmlns:vm="clr-namespace:Work_Practice.ViewModels"
        Title="Задание 1 – числа (процедура и функция)"
        Style="{StaticResource KasperskyWindowStyle}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Height="600" Width="800">
    <Window.DataContext>
        <vm:Task1ViewModel/>
    </Window.DataContext>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <RadioButton x:Name="ProcRadio" Content="Процедура" 
                         IsChecked="True" Margin="10,5" Foreground="White"/>
            <RadioButton x:Name="FuncRadio" Content="Функция" 
                         Margin="10,5" Foreground="White"/>
        </StackPanel>

        <ContentControl Margin="10">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Content">
                        <Setter.Value>
                            <uc:Task1ProcControl/>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=FuncRadio}" Value="True">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <uc:Task1FuncControl/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </DockPanel>
</Window>