<Window x:Class="Work_Practice.Views.Task1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uc="clr-namespace:Work_Practice.UserControls"
        xmlns:vm="clr-namespace:Work_Practice.ViewModels"
        Title="Задание 1 – числа (процедура и функция)"
        Style="{StaticResource KasperskyWindowStyle}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Height="900" Width="800">
    <Window.DataContext>
        <vm:Task1ViewModel/>
    </Window.DataContext>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <RadioButton Content="Процедура" IsChecked="{Binding IsProcSelected}" Margin="10,5" Foreground="White"/>
            <RadioButton Content="Функция" IsChecked="{Binding IsFuncSelected}" Margin="10,5" Foreground="White"/>
        </StackPanel>
        <uc:Task1ProcControl Margin="10"/>
    </DockPanel>
</Window>