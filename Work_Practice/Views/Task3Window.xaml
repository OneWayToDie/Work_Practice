<Window x:Class="Work_Practice.Views.Task3Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Work_Practice.ViewModels"
        xmlns:uc="clr-namespace:Work_Practice.UserControls"
        xmlns:conv="clr-namespace:Work_Practice.Converters"
        Title="Задание 3 – Односвязный список"
        Style="{StaticResource KasperskyWindowStyle}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Height="650" Width="800">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <vm:Task3ViewModel/>
    </Window.DataContext>
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <RadioButton Content="Собственная реализация" IsChecked="{Binding IsCustomViewSelected}" 
                         Margin="10,5" Foreground="White" GroupName="ListViewMode"/>
            <RadioButton Content="Реализация через LinkedList&lt;T&gt;" IsChecked="{Binding IsBuiltInViewSelected}" 
                         Margin="10,5" Foreground="White" GroupName="ListViewMode"/>
        </StackPanel>
        <Grid Margin="5">
            <uc:CustomListView Visibility="{Binding IsCustomViewSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <uc:BuiltInListView Visibility="{Binding IsBuiltInViewSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
    </DockPanel>
</Window>