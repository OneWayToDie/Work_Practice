<Window x:Class="Work_Practice.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Work_Practice.ViewModels"
        Title="Учебная практика (вариант 26)"
        Style="{StaticResource KasperskyWindowStyle}"
        Height="450" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,20,0,20">
            <TextBlock Text="Учебная практика" FontSize="28" FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Вариант 26 | Прикладная информатика в промышленности" 
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Задание 1" Style="{StaticResource KasperskyButton}" 
                    Width="160" Height="60" Margin="15" Command="{Binding OpenTask1Command}"/>
            <Button Content="Задание 2" Style="{StaticResource KasperskyButton}" 
                    Width="160" Height="60" Margin="15" Command="{Binding OpenTask2Command}"/>
            <Button Content="Задание 3" Style="{StaticResource KasperskyButton}" 
                    Width="160" Height="60" Margin="15" Command="{Binding OpenTask3Command}"/>
        </WrapPanel>

        <TextBlock Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                   Margin="0,0,0,15" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                   Text="Тульский государственный университет | Кафедра информационной безопасности"/>
    </Grid>
</Window>