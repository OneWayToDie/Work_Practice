<Window x:Class="Work_Practice.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Work_Practice.ViewModels"
        Title="Учебная практика (вариант 26)"
        Style="{StaticResource KasperskyWindowStyle}"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/Images/university.ico"
        Height="600" Width="800">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя надпись -->
        <StackPanel Grid.Row="0" Margin="0,20,0,20">
            <TextBlock Text="Учебная практика" FontSize="28" FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Вариант 26 | Прикладная информатика в промышленности" 
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Кнопки заданий с иконками -->
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <Button Style="{StaticResource MainTaskButton}" Command="{Binding OpenTask1Command}" Margin="15">
                <StackPanel>
                    <Image Source="/Resources/Images/calculator.png" Width="48" Height="48" Margin="0,0,0,10"/>
                    <TextBlock TextAlignment="Center" FontSize="16" FontWeight="SemiBold">Задание 1</TextBlock>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MainTaskButton}" Command="{Binding OpenTask2Command}" Margin="15">
                <StackPanel>
                    <Image Source="/Resources/Images/Boxes.png" Width="48" Height="48" Margin="0,0,0,10"/>
                    <TextBlock TextAlignment="Center" FontSize="16" FontWeight="SemiBold">Задание 2</TextBlock>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MainTaskButton}" Command="{Binding OpenTask3Command}" Margin="15">
                <StackPanel>
                    <Image Source="/Resources/Images/list.png" Width="48" Height="48" Margin="0,0,0,10"/>
                    <TextBlock TextAlignment="Center" FontSize="16" FontWeight="SemiBold">Задание 3</TextBlock>
                </StackPanel>
            </Button>
        </WrapPanel>

        <!-- Нижняя строка -->
        <TextBlock Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                   Margin="0,0,0,25" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                   Text="Тульский государственный университет | Кафедра информационной безопасности"/>
    </Grid>
</Window>