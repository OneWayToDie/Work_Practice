<UserControl x:Class="Work_Practice.UserControls.Task1FuncControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Строка ввода числа -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
            <TextBox x:Name="NumberInput" Width="200" Margin="0,0,10,0" 
                     ToolTip="Введите целое число"/>
            <Button x:Name="AddButton" Content="Добавить" 
                    Width="100" Click="AddButton_Click"/>
        </StackPanel>

        <!-- Список введённых чисел -->
        <ListBox x:Name="NumbersList" Grid.Row="1" Height="120" Margin="0,10"/>

        <!-- Кнопка обработки -->
        <Button x:Name="ProcessButton" Content="Обработать" 
                Grid.Row="2" Width="150" Height="35" Margin="0,10"
                Click="ProcessButton_Click"/>

        <!-- Таблица результатов -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="3" AutoGenerateColumns="False" 
                  Height="200" Margin="0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Число" Binding="{Binding Number}"/>
                <DataGridTextColumn Header="Количество цифр" Binding="{Binding DigitCount}"/>
                <DataGridTextColumn Header="Наименьшая цифра" Binding="{Binding MinDigit}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Текстовый блок с кодом функции -->
        <TextBox x:Name="CodeBlock" Grid.Row="4" 
                 TextWrapping="Wrap" IsReadOnly="True" 
                 FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" Height="150"
                 Text="(int count, int minDigit) GetDigitsInfoFunc(int number)&#x0a;{&#x0a;    if (number &lt;= 0) return (0, -1);&#x0a;    int temp = number;&#x0a;    int count = 0;&#x0a;    int minDigit = 9;&#x0a;    while (temp &gt; 0)&#x0a;    {&#x0a;        int digit = temp % 10;&#x0a;        if (digit &lt; minDigit) minDigit = digit;&#x0a;        count++;&#x0a;        temp /= 10;&#x0a;    }&#x0a;    return (count, minDigit);&#x0a;}"/>
    </Grid>
</UserControl>
